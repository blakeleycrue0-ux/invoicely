{%- comment -%}
  ============================================================================
  [BRAND] — Cinematic Intro (pre-rendered photoreal WebM/MP4 version)
  ----------------------------------------------------------------------------
  Same UX contract as intro.liquid:
    - Skippable, plays once per session (sessionStorage)
    - Respects prefers-reduced-motion (skips straight to the store)
    - Lazy-loads the video, scoped under #wb-intro, self-removing & fail-safe
  Set your hosted asset URLs on the data-* attributes below.
  ============================================================================
{%- endcomment -%}

<div id="wb-intro"
     data-webm="https://YOUR-CDN/intro.webm"
     data-mp4="https://YOUR-CDN/intro.mp4"
     data-poster="https://YOUR-CDN/intro-poster.jpg"
     aria-hidden="true" role="presentation">
  <video id="wb-intro-video" playsinline muted preload="auto"></video>
  <button type="button" id="wb-intro-skip" aria-label="Skip intro">Skip</button>
</div>

<style>
  #wb-intro{
    position:fixed; inset:0; z-index:2147483000; background:#000; overflow:hidden;
    opacity:1; transition:opacity 1s ease; -webkit-tap-highlight-color:transparent;
  }
  #wb-intro.wb-done{ opacity:0; pointer-events:none; }
  #wb-intro #wb-intro-video{
    position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block;
  }
  #wb-intro #wb-intro-skip{
    position:absolute; bottom:26px; right:26px;
    font:500 12px/1 -apple-system,BlinkMacSystemFont,"Segoe UI",Helvetica,Arial,sans-serif;
    letter-spacing:.22em; text-transform:uppercase;
    color:rgba(255,255,255,.55); background:transparent;
    border:1px solid rgba(255,255,255,.22); border-radius:999px;
    padding:10px 18px; cursor:pointer; opacity:0;
    transition:opacity .6s ease .8s, color .25s ease, border-color .25s ease;
    -webkit-appearance:none; appearance:none;
  }
  #wb-intro.wb-ready #wb-intro-skip{ opacity:1; }
  #wb-intro #wb-intro-skip:hover{ color:#fff; border-color:rgba(255,255,255,.6); }
  @media (max-width:600px){
    #wb-intro #wb-intro-skip{ bottom:18px; right:18px; padding:9px 15px; font-size:11px; }
  }
  @media (prefers-reduced-motion: reduce){ #wb-intro{ display:none !important; } }
</style>

<script>
(function () {
  "use strict";
  var root = document.getElementById("wb-intro");
  if (!root) return;
  var KEY = "wbIntroPlayed";
  var reduceMotion = window.matchMedia &&
    window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function removeNow(){ if (root && root.parentNode) root.parentNode.removeChild(root);
    document.documentElement.style.removeProperty("overflow"); }

  var played = false;
  try { played = sessionStorage.getItem(KEY) === "1"; } catch (e) {}
  if (reduceMotion || played) { removeNow(); return; }
  try { sessionStorage.setItem(KEY, "1"); } catch (e) {}

  document.documentElement.style.overflow = "hidden";

  var v = document.getElementById("wb-intro-video");
  var skip = document.getElementById("wb-intro-skip");
  var poster = root.getAttribute("data-poster");
  if (poster) v.setAttribute("poster", poster);

  var finished = false;
  function finish(){
    if (finished) return; finished = true;
    root.classList.add("wb-done");
    document.documentElement.style.removeProperty("overflow");
    try { v.pause(); v.removeAttribute("src"); v.load(); } catch (e) {}
    setTimeout(removeNow, 1100);
  }
  skip.addEventListener("click", finish);

  // build sources (webm first, mp4 fallback) and lazy-load
  function addSource(url, type){ if(!url||/YOUR-CDN/.test(url)) return false;
    var s=document.createElement("source"); s.src=url; s.type=type; v.appendChild(s); return true; }
  var has = false;
  has = addSource(root.getAttribute("data-webm"), "video/webm") || has;
  has = addSource(root.getAttribute("data-mp4"),  "video/mp4")  || has;
  if (!has) { finish(); return; }          // no real URLs set -> don't block the store

  v.addEventListener("ended", finish);
  v.addEventListener("error", finish);
  v.addEventListener("canplay", function(){ root.classList.add("wb-ready"); });

  // guard: never trap the visitor if playback stalls
  var guard = setTimeout(finish, 9000);
  v.addEventListener("ended", function(){ clearTimeout(guard); });

  v.load();
  var p = v.play();
  if (p && p.catch) p.catch(function(){ finish(); }); // autoplay blocked -> skip gracefully
})();
</script>
